rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // 커뮤니티 업로드 경로: community/{uid}/{postKey}/{type}/{filename}
    match /community/{uid}/{postKey}/{type}/{filename} {

      // 읽기: 누구나 가능 (공개 게시물)
      allow read: if true;

      // 쓰기: 로그인 사용자만, 본인 경로에만
      allow write: if
        request.auth != null
        && request.auth.uid == uid

        // 파일 크기 제한: 이미지 5MB, 오디오 10MB
        && (
          (type == "image" && request.resource.size <= 5 * 1024 * 1024)
          || (type == "audio" && request.resource.size <= 10 * 1024 * 1024)
        )

        // 허용 MIME 타입
        && (
          request.resource.contentType.matches('image/(jpeg|png|gif|webp)')
          || request.resource.contentType.matches('audio/(mpeg|mp4|ogg|wav|x-m4a)')
        );

      // 삭제: 본인만 가능
      allow delete: if request.auth != null && request.auth.uid == uid;
    }
  }
}
