rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.uid == "48n4hAjZUbTPR4pBIAJzqivJhp42";
    }

    function isLoggedIn() {
      return request.auth != null;
    }

    match /tools/{toolId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /communityPosts/{postId} {
      allow read: if true;
      allow create: if isLoggedIn();
      allow update: if isLoggedIn() && (
        request.auth.uid == resource.data.uid || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvoteCount', 'downvoteCount', 'reportCount', 'views']))
      );
      allow delete: if isAdmin() || (isLoggedIn() && request.auth.uid == resource.data.uid);

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isLoggedIn();
        allow update: if isLoggedIn() && request.auth.uid == resource.data.uid;
        allow delete: if isAdmin() || (isLoggedIn() && request.auth.uid == resource.data.uid);
      }
    }

    match /communityVotes/{voteId} {
      allow read: if true;
      allow write: if isLoggedIn() && voteId.startsWith(request.auth.uid);
    }

    match /communityReports/{reportId} {
      allow read: if isAdmin();
      allow write: if isLoggedIn() && reportId.startsWith(request.auth.uid);
    }

    match /galleryPosts/{postId} {
      allow read: if true;
      allow create: if isLoggedIn();
      allow update: if isLoggedIn();
      allow delete: if isAdmin() || (isLoggedIn() && request.auth.uid == resource.data.uid);
    }

    match /users/{uid} {
      allow read: if isLoggedIn();
      allow write: if request.auth.uid == uid;
    }

    match /bannedUsers/{uid} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    match /bookmarks/{docId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow delete: if isLoggedIn() && request.auth.uid == resource.data.uid;
    }

    match /toolReactions/{docId} {
      allow read: if true;
      allow write: if isLoggedIn();
    }

    match /userDailyLimits/{uid} {
      allow read, write: if isLoggedIn() && request.auth.uid == uid;
    }
  }
}
